@model List<VistaDepartamento>

@{
    int numRegistros = (int)@ViewData["NUMREGISTROS"];
    int numPagina = 1;
}

<h1>Paginación en grupo</h1>

<hr/>
<div>
    @for (int i = 1; i <= numRegistros; i += 2)
    {
        <a asp-controller="Paginacion" asp-action="GrupoVistaDepartamentos" asp-route-posicion="@i">Página @numPagina </a>
        ;
        numPagina++;
    }
</div>
<hr />

<table class="table table-warning">
    <thead>
        <tr>
            <th>Posición</th>
            <th>Id</th>
            <th>Nombre</th>
            <th>Localidad</th>
        </tr>
    </thead>
<tbody>
    @foreach (VistaDepartamento dept in Model)
    {
    <tr>
        <td>@dept.Posicion</td>
        <td>@dept.IdDepartamento</td>
        <td>@dept.Nombre</td>
        <td>@dept.Localidad</td>
    </tr>
        }
</table>